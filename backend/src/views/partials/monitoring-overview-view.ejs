<section
	x-data='monitoringPageState({
		seasonId: <%- JSON.stringify(selectedSeasonId) %>,
		communityGroups: <%- JSON.stringify(communityGroups) %>
	})'
	class="card bg-base-100 shadow lg:h-full lg:min-h-0 lg:overflow-hidden">
	<div class="card-body gap-4 p-4 lg:h-full lg:min-h-0 lg:overflow-hidden">
		<section class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
			<label class="form-control w-full md:max-w-sm">
				<span class="label-text mb-2 font-semibold">Buscar</span>
				<div class="relative">
					<input
						class="input input-bordered w-full pr-10"
						type="text"
						name="monitoringSearch"
						autocomplete="off"
						placeholder="Buscar por comunidad, permiso o encargado"
						x-model="search" />
					<button
						type="button"
						x-cloak
						x-show="search.trim()"
						class="absolute inset-y-0 right-2 flex cursor-pointer items-center text-slate-400 transition hover:text-slate-700"
						@click="search = ''">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M18 6 6 18"/>
							<path d="m6 6 12 12"/>
						</svg>
					</button>
				</div>
			</label>

			<div class="flex items-center gap-2">
				<button
					type="button"
					class="btn btn-outline btn-sm"
					@click="expandAll()">
					Expandir todo
				</button>
				<button
					type="button"
					class="btn btn-outline btn-sm"
					@click="collapseAll()">
					Cerrar todo
				</button>
			</div>
		</section>

		<div
			x-ref="scrollContainer"
			@scroll="handleScroll()"
			class="flex min-h-0 h-0 flex-1 basis-0 flex-col gap-3 overflow-y-auto pr-1">
			<template x-if="filteredCommunityGroups.length === 0">
				<div class="flex min-h-full items-center justify-center px-3 py-4 text-center text-sm text-slate-500">
					No se encontraron permisos para esta busqueda.
				</div>
			</template>

			<template x-for="community in filteredCommunityGroups" :key="community.communityId">
				<section class="rounded-xl border border-base-300 bg-base-100">
					<button
						type="button"
						class="flex w-full items-center justify-between gap-3 px-3 py-2 text-left transition hover:bg-base-200/50"
						@click="toggleCommunity(community.communityId)">
						<div class="min-w-0">
							<h2 class="truncate text-sm font-semibold text-slate-900" x-text="community.communityName"></h2>
						</div>

						<div class="flex items-center gap-3">
							<span class="text-xs text-slate-500">
								<span x-text="community.permits.length"></span> permisos
							</span>
							<svg
								class="h-4 w-4 text-slate-500 transition"
								:class="isExpanded(community.communityId) ? 'rotate-90' : ''"
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true">
								<path d="m9 18 6-6-6-6"/>
							</svg>
						</div>
					</button>

					<div
						x-show="isExpanded(community.communityId)"
						class="border-t border-base-200 px-3 py-3">
						<div class="grid grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-3">
							<template x-for="permit in community.permits" :key="permit.permitId">
								<a
									:href="permitHref(permit.permitId)"
									class="block rounded-xl border border-base-300 bg-base-100 px-3 py-2 text-left transition hover:border-primary/40 hover:bg-base-100"
									@click="saveState()">
									<div class="flex items-start justify-between gap-3">
										<div class="min-w-0 flex-1">
											<div class="truncate text-sm font-semibold text-slate-900">
												Permiso <span x-text="permit.permitNumber"></span>
											</div>
											<div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
												<span
													title="Participantes"
													class="badge badge-outline badge-sm inline-flex items-center gap-1.5"
													:class="permit.isSynced ? 'text-slate-900' : 'text-slate-400'">
													<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
														<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
														<path d="M16 3.128a4 4 0 0 1 0 7.744"/>
														<path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
														<circle cx="9" cy="7" r="4"/>
													</svg>
													<span x-text="permit.isSynced ? permit.participantsCount : '-'"></span>
												</span>
												<span
													title="Registros de esquila"
													class="badge badge-outline badge-sm inline-flex items-center gap-1.5"
													:class="permit.isSynced ? 'text-slate-900' : 'text-slate-400'">
													<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
														<circle cx="6" cy="6" r="3"/>
														<path d="M8.12 8.12 12 12"/>
														<path d="M20 4 8.12 15.88"/>
														<circle cx="6" cy="18" r="3"/>
														<path d="M14.8 14.8 20 20"/>
													</svg>
													<span x-text="permit.isSynced ? permit.shearingRecordsCount : '-'"></span>
												</span>
												<span
													title="Registros de limpieza"
													class="badge badge-outline badge-sm inline-flex items-center gap-1.5"
													:class="permit.isSynced ? 'text-slate-900' : 'text-slate-400'">
													<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
														<path d="m16 22-1-4"/>
														<path d="M19 14a1 1 0 0 0 1-1v-1a2 2 0 0 0-2-2h-3a1 1 0 0 1-1-1V4a2 2 0 0 0-4 0v5a1 1 0 0 1-1 1H6a2 2 0 0 0-2 2v1a1 1 0 0 0 1 1"/>
														<path d="M19 14H5l-1.973 6.767A1 1 0 0 0 4 22h16a1 1 0 0 0 .973-1.233z"/>
														<path d="m8 22 1-4"/>
													</svg>
													<span x-text="permit.isSynced ? permit.cleaningRecordsCount : '-'"></span>
												</span>
											</div>
										</div>

										<div class="shrink-0 pt-0.5">
											<template x-if="permit.isSynced">
												<span title="Sincronizado" class="inline-flex text-emerald-600">
													<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
														<path d="m17 15-5.5 5.5L9 18"/>
														<path d="M5.516 16.07A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 3.501 7.327"/>
													</svg>
												</span>
											</template>
											<template x-if="!permit.isSynced">
												<span title="Pendiente" class="inline-flex text-warning">
													<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
														<path d="m17 18-1.535 1.605a5 5 0 0 1-8-1.5"/>
														<path d="M17 22v-4h-4"/>
														<path d="M20.996 15.251A4.5 4.5 0 0 0 17.495 8h-1.79a7 7 0 1 0-12.709 5.607"/>
														<path d="M7 10v4h4"/>
														<path d="m7 14 1.535-1.605a5 5 0 0 1 8 1.5"/>
													</svg>
												</span>
											</template>
										</div>
									</div>
								</a>
							</template>
						</div>
					</div>
				</section>
			</template>
		</div>
	</div>
</section>
