<article class="card bg-base-100 shadow lg:h-full lg:min-h-0 lg:overflow-hidden">
	<div class="card-body gap-4 p-4 lg:h-full lg:min-h-0 lg:overflow-hidden">
		<div class="flex min-h-0 flex-1 flex-col gap-4 overflow-y-auto pr-1">
			<section class="flex flex-col gap-3 rounded-xl border border-base-300 bg-base-100 p-3 md:flex-row md:items-start md:justify-between">
				<div class="flex min-w-0 items-start gap-3">
					<a
						href="/admin/monitoring?<%= new URLSearchParams({ seasonId: selectedSeasonId }).toString() %>"
						class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-base-300 text-slate-600 transition hover:border-primary/40 hover:text-slate-900">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="m12 19-7-7 7-7"/>
							<path d="M19 12H5"/>
						</svg>
					</a>

					<div class="min-w-0">
						<h2 class="truncate text-base font-semibold text-slate-900">
							Permiso <%= selectedPermit.permitNumber %>
						</h2>
						<p class="truncate text-sm text-slate-500">
							<%= selectedPermit.communityName %>
						</p>
					</div>
				</div>

				<div class="flex flex-wrap items-center gap-2 md:justify-end">
					<% if (selectedPermit.isSynced) { %>
						<button
							type="button"
							class="btn btn-outline btn-sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/>
								<path d="M14 2v5a1 1 0 0 0 1 1h5"/>
								<path d="M8 13h2"/>
								<path d="M14 13h2"/>
								<path d="M8 17h2"/>
								<path d="M14 17h2"/>
							</svg>
							Generar reportes
						</button>
						<span class="inline-flex items-center gap-2 rounded-full bg-emerald-100 px-3 py-2 text-xs font-medium text-emerald-700">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="m17 15-5.5 5.5L9 18"/>
								<path d="M5.516 16.07A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 3.501 7.327"/>
							</svg>
							<%= selectedPermit.syncedAtLabel %>
						</span>
					<% } else { %>
						<span class="inline-flex items-center gap-2 rounded-full bg-warning/20 px-3 py-2 text-xs font-medium text-warning-content">
							Pendiente
						</span>
					<% } %>
				</div>
			</section>

			<section class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3">
				<div class="rounded-xl border border-base-300 bg-base-100 p-2.5">
					<div class="flex items-center gap-2 text-sm text-slate-900">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
							<path d="M16 3.128a4 4 0 0 1 0 7.744"/>
							<path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
							<circle cx="9" cy="7" r="4"/>
						</svg>
						<span>Participantes</span>
					</div>
					<p class="mt-2 text-2xl font-semibold text-slate-900">
						<%= selectedPermit.participantsCount ?? "-" %>
					</p>
				</div>

				<div class="rounded-xl border border-base-300 bg-base-100 p-2.5">
					<div class="flex items-center gap-2 text-sm text-slate-900">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="6" cy="6" r="3"/>
							<path d="M8.12 8.12 12 12"/>
							<path d="M20 4 8.12 15.88"/>
							<circle cx="6" cy="18" r="3"/>
							<path d="M14.8 14.8 20 20"/>
						</svg>
						<span>Registros esquila</span>
					</div>
					<p class="mt-2 text-2xl font-semibold text-slate-900">
						<%= selectedPermit.shearingRecordsCount ?? "-" %>
					</p>
				</div>

				<div class="rounded-xl border border-base-300 bg-base-100 p-2.5">
					<div class="flex items-center gap-2 text-sm text-slate-900">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="m16 22-1-4"/>
							<path d="M19 14a1 1 0 0 0 1-1v-1a2 2 0 0 0-2-2h-3a1 1 0 0 1-1-1V4a2 2 0 0 0-4 0v5a1 1 0 0 1-1 1H6a2 2 0 0 0-2 2v1a1 1 0 0 0 1 1"/>
							<path d="M19 14H5l-1.973 6.767A1 1 0 0 0 4 22h16a1 1 0 0 0 .973-1.233z"/>
							<path d="m8 22 1-4"/>
						</svg>
						<span>Registros limpieza</span>
					</div>
					<p class="mt-2 text-2xl font-semibold text-slate-900">
						<%= selectedPermit.cleaningRecordsCount ?? "-" %>
					</p>
				</div>
			</section>

			<section class="rounded-xl border border-base-300 bg-base-100 p-3">
				<div class="flex items-center justify-between gap-3">
					<h3 class="text-sm font-semibold text-slate-900">
						Asignados
					</h3>
				</div>

				<div class="mt-3 flex flex-col gap-2">
					<% selectedPermit.users.forEach((user) => { %>
						<div class="flex items-center justify-between gap-3 rounded-xl border border-base-300 bg-base-100 px-3 py-1.5">
							<div class="min-w-0">
								<p class="truncate text-sm font-medium text-slate-900">
									<%= user.fullName %>
								</p>
							</div>

							<div class="shrink-0">
								<% if (user.active) { %>
									<span title="<%= selectedPermit.isSynced ? 'Sincronizo el permiso' : 'Encargado principal' %>" class="inline-flex text-emerald-600">
										<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
											<path d="M4 22V4a1 1 0 0 1 .4-.8A6 6 0 0 1 8 2c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10a1 1 0 0 1-.4.8A6 6 0 0 1 16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528"/>
										</svg>
									</span>
								<% } %>
							</div>
						</div>
					<% }) %>
				</div>
			</section>
		</div>
	</div>
</article>
