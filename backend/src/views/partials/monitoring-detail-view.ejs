<article class="card bg-base-100 shadow lg:h-full lg:min-h-0 lg:overflow-hidden">
	<div class="card-body gap-4 p-4 lg:h-full lg:min-h-0">
		<div class="flex items-center gap-3">
			<a
				href="/admin/monitoring?<%= new URLSearchParams({ seasonId: selectedSeasonId }).toString() %>"
				class="flex h-9 w-9 items-center justify-center rounded-full border border-base-300 text-slate-600 transition hover:border-primary/40 hover:text-slate-900">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="m12 19-7-7 7-7"/>
					<path d="M19 12H5"/>
				</svg>
			</a>

			<div class="min-w-0">
				<h2 class="truncate text-base font-semibold text-slate-900">
					Permiso <%= selectedPermit.permitNumber %>
				</h2>
				<p class="truncate text-sm text-slate-500">
					<%= selectedPermit.communityName %>
				</p>
			</div>
		</div>

		<div class="flex min-h-72 items-center justify-center rounded-xl border border-dashed border-base-300 bg-base-100 px-4 text-center text-sm text-slate-500 lg:min-h-0 lg:flex-1">
			Detalle en construccion.
		</div>
	</div>
</article>
