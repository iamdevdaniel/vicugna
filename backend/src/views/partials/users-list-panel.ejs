<div class="divide-y divide-base-300">
	<% if (users.length === 0) { %>
		<p class="px-5 py-8 text-sm text-slate-500"><%= emptyMessage %></p>
	<% } %>

	<% users.forEach((user) => { %>
		<article class="flex flex-col gap-2 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
			<div>
				<h3 class="font-semibold text-slate-900"><%= user.fullName %></h3>
				<p class="text-sm text-slate-500">
					<%= user.phoneNumber %>
					<span class="px-2 text-slate-300">•</span>
					<%= user.email || "Sin correo" %>
				</p>
			</div>

			<div class="flex flex-wrap items-center gap-2">
				<span class="badge <%= user.isActive ? "badge-success badge-soft" : "badge-neutral badge-soft" %>">
					<%= user.isActive ? "Activo" : "Inactivo" %>
				</span>
			</div>
		</article>
	<% }) %>
</div>
