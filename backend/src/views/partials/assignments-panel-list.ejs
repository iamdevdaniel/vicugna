<article class="card bg-base-100 shadow lg:h-full lg:min-h-0 lg:overflow-hidden">
	<div class="card-body gap-4 p-4 lg:h-full lg:min-h-0 lg:overflow-hidden">
		<h2 class="text-base font-semibold text-slate-900">Asignaciones actuales</h2>

		<section class="space-y-2">
			<label class="form-control">
				<span class="label-text mb-2 font-semibold">Buscar</span>
				<div class="relative">
					<input
						class="input input-bordered w-full pr-10"
						type="text"
						name="assignmentSearch"
						autocomplete="off"
						placeholder="Buscar por permiso o usuario"
						x-model="assignmentSearch" />
					<button
						type="button"
						x-cloak
						x-show="assignmentSearch.trim()"
						class="absolute inset-y-0 right-2 flex cursor-pointer items-center text-slate-400 transition hover:text-slate-700"
						@click="assignmentSearch = ''">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M18 6 6 18"/>
							<path d="m6 6 12 12"/>
						</svg>
					</button>
				</div>
			</label>
		</section>

		<div class="flex min-h-0 h-0 flex-1 basis-0 flex-col gap-1.5 overflow-y-auto pr-1">
				<div
					x-show="assignmentCards.length > 0 && filteredAssignmentCards.length === 0"
					x-cloak
					class="flex min-h-full items-center justify-center px-3 py-4 text-center text-sm text-slate-500">
					No se encontraron asignaciones para esta busqueda.
				</div>

				<% if (assignments.length === 0) { %>
					<div class="flex min-h-full items-center justify-center px-3 py-4 text-center text-sm text-slate-500">
						Aun no hay asignaciones guardadas.
					</div>
				<% } %>

				<template x-for="card in filteredAssignmentCards" :key="card.permitId">
					<article
						:data-assignment-card-id="card.permitId"
						class="cursor-pointer rounded-xl border px-3 py-2 text-left transition"
						:class="selectedPermitId === card.permitId
							? 'border-primary bg-primary/5'
							: 'border-base-300 bg-base-100'"
						@click="selectPermitById(card.permitId)">
						<div class="flex items-start justify-between gap-3">
							<div>
								<div class="text-sm font-semibold text-slate-900">
									Permiso <span x-text="card.permitNumber"></span>
								</div>
							</div>
							<span class="badge badge-outline badge-sm" x-text="assignmentCardBadge(card)">
							</span>
						</div>

						<div class="mt-1 space-y-0">
							<template x-for="user in card.users" :key="user.assignmentId">
								<div class="flex items-center justify-between gap-3 py-1">
									<div class="min-w-0 truncate text-sm text-slate-700" x-text="user.userFullName"></div>
									<div
										class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full"
										:class="user.active ? 'text-success' : 'text-slate-300'">
										<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
											<path d="M4 22V4a1 1 0 0 1 .4-.8A6 6 0 0 1 8 2c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10a1 1 0 0 1-.4.8A6 6 0 0 1 16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528"/>
										</svg>
									</div>
								</div>
							</template>
						</div>
					</article>
				</template>
		</div>
	</div>
</article>
