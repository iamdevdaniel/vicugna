<article class="card bg-base-100 shadow lg:h-full lg:min-h-0 lg:overflow-hidden">
	<div class="card-body gap-4 p-4 lg:h-full lg:min-h-0 lg:overflow-hidden">
		<h2 class="text-base font-semibold text-slate-900">Asignaciones actuales</h2>

		<section class="space-y-2">
			<label class="form-control">
				<span class="label-text mb-2 font-semibold">Buscar</span>
				<input
					class="input input-bordered w-full"
					type="text"
					name="assignmentSearch"
					autocomplete="off"
					placeholder="Buscar por comunidad, permiso o usuario"
					x-model="assignmentSearch" />
			</label>
		</section>

		<div class="rounded-box flex min-h-0 flex-1 basis-0 flex-col border border-base-300 bg-base-200/40 p-2 lg:overflow-hidden">
			<div class="flex min-h-0 h-0 flex-1 basis-0 flex-col gap-2 overflow-y-auto pr-1">
				<div
					x-show="filteredAssignmentCards.length === 0"
					x-cloak
					class="rounded-lg border border-dashed border-base-300 bg-base-100 px-3 py-4 text-sm text-slate-500">
					No hay asignaciones para mostrar.
				</div>

				<% if (assignments.length === 0) { %>
					<div class="rounded-lg border border-dashed border-base-300 bg-base-100 px-3 py-4 text-sm text-slate-500">
						Aun no hay asignaciones guardadas.
					</div>
				<% } %>

				<template x-for="card in filteredAssignmentCards" :key="card.permitId">
					<article
						class="rounded-xl border px-3 py-3 text-left transition"
						:class="selectedPermitId === card.permitId
							? 'border-primary bg-primary/5'
							: 'border-base-300 bg-base-100'"
						@click="selectPermitById(card.permitId)">
						<div class="flex items-start justify-between gap-3">
							<div>
								<div class="text-sm font-semibold text-slate-900" x-text="card.communityName">
								</div>
								<div class="mt-1 text-xs text-slate-500">
									Permiso <span x-text="card.permitNumber"></span>
								</div>
							</div>
							<span class="badge badge-outline badge-sm" x-text="assignmentCardBadge(card)">
							</span>
						</div>

						<div class="mt-3 space-y-2">
							<template x-for="user in card.users" :key="user.assignmentId">
								<div class="flex items-center justify-between gap-3 rounded-lg border border-base-200 px-2 py-2">
									<div class="text-sm text-slate-700" x-text="user.userFullName"></div>
									<div class="flex items-center gap-2">
										<span
											class="badge badge-sm"
											:class="user.active ? 'badge-success badge-soft' : 'badge-ghost'"
											x-text="user.active ? 'Activo' : 'Respaldo'"></span>
										<button type="button" class="btn btn-ghost btn-xs" @click.stop>
											Activo
										</button>
										<button type="button" class="btn btn-ghost btn-xs text-error" @click.stop>
											Eliminar
										</button>
									</div>
								</div>
							</template>
						</div>
					</article>
				</template>
			</div>
		</div>
	</div>
</article>
