<article class="card bg-base-100 shadow lg:h-full">
	<div class="card-body gap-4 p-4 lg:h-full lg:min-h-0 lg:overflow-hidden">
		<h2 class="text-base font-semibold text-slate-900">Asignar usuarios</h2>

		<section>
			<div class="text-center text-lg font-semibold text-slate-900" x-text="selectedPermit ? selectedPermit.permitNumber : '-'">
			</div>
		</section>

		<form method="post" action="/admin/assignments" class="flex h-full min-h-0 flex-col lg:overflow-hidden" @submit="skipUnloadWarning = true">
			<input type="hidden" name="seasonId" value="<%= selectedSeasonId %>" />
			<input type="hidden" name="communityId" x-model="selectedCommunityId" />
			<input type="hidden" name="permitId" x-model="selectedPermitId" />
			<input type="hidden" name="activeUserId" :value="panel2ActiveUserId" />
			<template x-for="user in panel2Users" :key="`input-${user.source}-${user.userId}`">
				<input type="hidden" name="userIds" :value="user.userId" />
			</template>

			<section class="relative space-y-2" @click.outside="isUserDropdownOpen = false">
				<label class="form-control">
					<span class="label-text mb-2 font-semibold">Encargado</span>
					<input
						class="input input-bordered w-full"
						type="text"
						name="userSearch"
						autocomplete="off"
						placeholder="Buscar encargado"
						x-model="userSearch"
						@focus="isUserDropdownOpen = true"
						@input="isUserDropdownOpen = true"
						:disabled="!selectedPermit" />
				</label>

				<div
					x-show="isUserDropdownOpen"
					x-cloak
					class="absolute inset-x-0 top-full z-10 mt-1 overflow-hidden rounded-box border border-base-300 bg-base-100 shadow-lg">
					<ul class="menu w-full p-0 text-sm">
					<template x-for="user in eligibleUsers" :key="user.id">
						<li class="w-full">
							<button
								type="button"
								class="flex w-full justify-start rounded-none px-3 py-2 text-left"
								@click="addUserToDraft(user)">
								<span x-text="user.name"></span>
							</button>
						</li>
					</template>
						<li x-show="eligibleUsers.length === 0">
							<div class="px-3 py-2 text-sm text-slate-500">
								Sin resultados
							</div>
						</li>
					</ul>
				</div>
			</section>

			<section class="flex min-h-0 flex-1 basis-0 flex-col lg:overflow-hidden">
				<div class="flex min-h-0 flex-1 basis-0 flex-col gap-2 overflow-y-auto pr-1">
					<div
						x-show="!selectedPermit"
						x-cloak
						class="flex min-h-full items-center justify-center px-3 py-4 text-center text-sm text-slate-500">
						Selecciona un permiso primero.
					</div>

					<div
						x-show="selectedPermit && panel2Users.length === 0"
						x-cloak
						class="flex min-h-full items-center justify-center px-3 py-4 text-center text-sm text-slate-500">
						Aun no hay usuarios asignados a este permiso.
					</div>

					<template x-for="user in panel2Users" :key="`${user.source}-${user.userId}`">
						<div class="flex items-center justify-between gap-3 rounded-xl border border-base-300 bg-base-100 px-3 py-2">
							<div class="min-w-0">
								<div class="truncate text-sm font-medium text-slate-900" x-text="user.userFullName"></div>
								<div class="mt-1 flex items-center gap-2 text-xs text-slate-500">
									<span
										class="badge badge-sm"
										:class="user.source === 'saved' ? 'badge-ghost' : 'badge-info badge-soft'"
										x-text="user.source === 'saved' ? 'Guardado' : 'Nuevo'"></span>
								</div>
							</div>
							<div class="flex items-center gap-2">
								<button
									type="button"
									class="flex h-8 w-8 items-center justify-center rounded-full transition"
									:class="user.active
										? 'cursor-pointer text-success hover:bg-success hover:text-white'
										: 'cursor-pointer text-slate-400 hover:bg-success hover:text-white'"
									@click="setDraftUserActive(user.userId)">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M4 22V4a1 1 0 0 1 .4-.8A6 6 0 0 1 8 2c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10a1 1 0 0 1-.4.8A6 6 0 0 1 16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528"/>
									</svg>
								</button>
								<button
									type="button"
									class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-slate-400 transition hover:bg-error hover:text-white"
									@click="removeDraftUser(user.userId)">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M18 6 6 18"/>
										<path d="m6 6 12 12"/>
									</svg>
								</button>
							</div>
						</div>
					</template>
				</div>
			</section>

			<div class="pt-2">
				<button type="submit" class="btn btn-primary w-full" :disabled="!selectedPermit || !isSelectedPermitDirty || panel2Users.length === 0">
					<span x-text="panel2SubmitLabel"></span>
				</button>
			</div>
		</form>
	</div>
</article>
