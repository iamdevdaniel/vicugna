<article class="card bg-base-100 shadow lg:h-full">
	<div class="card-body gap-4 p-4 lg:h-full lg:min-h-0 lg:overflow-hidden">
		<h2 class="text-base font-semibold text-slate-900">Configurar permiso</h2>

		<section>
			<div
				x-show="!selectedPermit"
				x-cloak
				class="text-center text-lg font-semibold text-slate-900">
				-
			</div>

			<div x-show="selectedPermit" x-cloak>
				<form
					method="post"
					action="/admin/assignments/permits/rename"
					class="mx-auto grid w-full max-w-md grid-cols-[2rem_minmax(0,1fr)_2rem] items-center gap-2"
					@submit="skipUnloadWarning = true">
					<input type="hidden" name="seasonId" value="<%= selectedSeasonId %>" />
					<input type="hidden" name="communityId" x-model="selectedCommunityId" />
					<input type="hidden" name="permitId" x-model="selectedPermitId" />

					<div x-show="!isEditingPermitName" x-cloak class="contents">
						<div class="col-start-2 flex min-w-0 items-center justify-center">
							<div class="truncate border-b border-transparent text-center text-lg font-semibold text-slate-900" x-text="selectedPermit ? selectedPermit.permitNumber : ''"></div>
						</div>
						<div class="col-start-3 flex items-center justify-center">
							<button
								type="button"
								class="flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-full text-slate-400 transition hover:bg-base-200 hover:text-slate-700"
								@click="startPermitRename()">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M13 21h8"/>
									<path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/>
								</svg>
							</button>
						</div>
					</div>

					<div
						x-show="isEditingPermitName"
						x-cloak
						class="col-span-3 grid grid-cols-[2rem_minmax(0,1fr)_2rem] items-center gap-2">
						<div class="flex items-center justify-center">
							<button
								type="button"
								class="flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-full text-slate-400 transition hover:bg-base-200 hover:text-slate-700"
								@click="cancelPermitRename()">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M18 6 6 18"/>
									<path d="m6 6 12 12"/>
								</svg>
							</button>
						</div>
						<input
							x-ref="permitNameInput"
							class="w-full border-0 border-b border-base-300 bg-transparent px-0 py-1 text-center text-lg font-semibold text-slate-900 outline-none focus:border-primary focus:outline-none focus:ring-0"
							type="text"
							name="permitNumber"
							autocomplete="off"
							x-model="permitNameDraft"
							@keydown.escape.prevent="cancelPermitRename()" />
						<div class="flex items-center justify-center">
							<button
								type="submit"
								class="flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-full text-slate-400 transition hover:bg-primary hover:text-white disabled:cursor-default disabled:opacity-40 disabled:hover:bg-transparent disabled:hover:text-slate-400"
								:disabled="!canSubmitPermitRename">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
									<path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/>
									<path d="M7 3v4a1 1 0 0 0 1 1h7"/>
								</svg>
							</button>
						</div>
					</div>
				</form>
			</div>
		</section>

		<form method="post" action="/admin/assignments" class="flex h-full min-h-0 flex-col lg:overflow-hidden" @submit="skipUnloadWarning = true">
			<input type="hidden" name="seasonId" value="<%= selectedSeasonId %>" />
			<input type="hidden" name="communityId" x-model="selectedCommunityId" />
			<input type="hidden" name="permitId" x-model="selectedPermitId" />
			<input type="hidden" name="activeUserId" :value="panel2ActiveUserId" />
			<template x-for="user in panel2Users" :key="`input-${user.source}-${user.userId}`">
				<input type="hidden" name="userIds" :value="user.userId" />
			</template>

			<section class="relative space-y-2" @click.outside="isUserDropdownOpen = false">
				<label class="form-control">
					<span class="label-text mb-2 font-semibold">Encargado</span>
					<div class="relative">
						<input
							class="input input-bordered w-full pr-10"
							type="text"
							name="userSearch"
							autocomplete="off"
							placeholder="Buscar encargado"
							x-model="userSearch"
							@focus="isUserDropdownOpen = true"
							@input="isUserDropdownOpen = true"
							:disabled="!selectedPermit" />
						<button
							type="button"
							x-cloak
							x-show="userSearch.trim()"
							class="absolute inset-y-0 right-2 flex cursor-pointer items-center text-slate-400 transition hover:text-slate-700"
							@click="
								userSearch = ''
								isUserDropdownOpen = true
							"
							:disabled="!selectedPermit">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M18 6 6 18"/>
								<path d="m6 6 12 12"/>
							</svg>
						</button>
					</div>
				</label>

				<div
					x-show="isUserDropdownOpen"
					x-cloak
					class="absolute inset-x-0 top-full z-10 mt-1 overflow-hidden rounded-box border border-base-300 bg-base-100 shadow-lg">
					<ul class="menu w-full p-0 text-sm">
					<template x-for="user in eligibleUsers" :key="user.id">
						<li class="w-full">
							<button
								type="button"
								class="flex w-full justify-start rounded-none px-3 py-2 text-left transition-none"
								@click="addUserToDraft(user)">
								<span x-text="user.name"></span>
							</button>
						</li>
					</template>
						<li x-show="eligibleUsers.length === 0">
							<div class="px-3 py-2 text-sm text-slate-500">
								Sin resultados
							</div>
						</li>
					</ul>
				</div>
			</section>

			<section class="mt-2 flex min-h-0 flex-1 basis-0 flex-col lg:overflow-hidden">
				<div class="flex min-h-0 flex-1 basis-0 flex-col gap-2 overflow-y-auto pr-1">
					<div
						x-show="!selectedPermit"
						x-cloak
						class="flex min-h-full items-center justify-center px-3 py-4 text-center text-sm text-slate-500">
						Selecciona un permiso primero.
					</div>

					<div
						x-show="selectedPermit && panel2Users.length === 0"
						x-cloak
						class="flex min-h-full items-center justify-center px-3 py-4 text-center text-sm text-slate-500">
						Aun no hay usuarios asignados a este permiso.
					</div>

					<template x-for="user in panel2Users" :key="`${user.source}-${user.userId}`">
						<div class="flex items-center justify-between gap-3 rounded-xl border border-base-300 bg-base-100 px-3 py-2">
							<div class="min-w-0">
								<div class="truncate text-sm font-medium text-slate-900" x-text="user.userFullName"></div>
								<div class="mt-1 flex items-center gap-2 text-xs text-slate-500">
									<span
										class="badge badge-sm"
										:class="user.source === 'saved' ? 'badge-ghost' : 'badge-info badge-soft'"
										x-text="user.source === 'saved' ? 'Guardado' : 'Nuevo'"></span>
								</div>
							</div>
							<div class="flex items-center gap-2">
								<button
									type="button"
									class="flex h-8 w-8 items-center justify-center rounded-full transition"
									:class="user.active
										? 'cursor-pointer text-success hover:bg-success hover:text-white'
										: 'cursor-pointer text-slate-400 hover:bg-success hover:text-white'"
									@click="setDraftUserActive(user.userId)">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M4 22V4a1 1 0 0 1 .4-.8A6 6 0 0 1 8 2c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10a1 1 0 0 1-.4.8A6 6 0 0 1 16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528"/>
									</svg>
								</button>
								<button
									type="button"
									class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-slate-400 transition hover:bg-error hover:text-white"
									@click="removeDraftUser(user.userId)">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M18 6 6 18"/>
										<path d="m6 6 12 12"/>
									</svg>
								</button>
							</div>
						</div>
					</template>
				</div>
			</section>

			<div class="pt-2">
				<button
					type="submit"
					class="btn w-full"
					:class="hasSavedUsersForSelectedPermit ? 'btn-info text-white hover:text-white' : 'btn-primary'"
					:disabled="!selectedPermit || !isSelectedPermitDirty || panel2Users.length === 0">
					<span x-text="panel2SubmitLabel"></span>
				</button>
			</div>
		</form>
	</div>
</article>
