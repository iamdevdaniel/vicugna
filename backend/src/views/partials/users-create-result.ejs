<% if (errorMessage) { %>
	<div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-3 text-sm text-rose-700">
		<%= errorMessage %>
	</div>
<% } %>

<% if (successMessage) { %>
	<%- include("./users-list", { users, useOobSwap: true }) %>
	<%- include("./toast", { message: successMessage }) %>
<% } %>
