<%
	const regularUsers = users.filter((user) => user.role === "user")
	const adminUsers = users.filter((user) => user.role === "admin")
%>

<section id="users-page" <% if (typeof useOobSwap !== "undefined" && useOobSwap) { %>hx-swap-oob="outerHTML"<% } %> class="mt-6 rounded-lg border border-slate-200 bg-white shadow-lg shadow-slate-900/5">
	<div class="border-b border-slate-200 px-5 pt-5">
		<h2 class="text-lg font-semibold text-slate-900">Usuarios registrados</h2>

		<nav class="mt-5 flex gap-2" aria-label="Tipos de usuario">
			<a href="#users"
				class="inline-flex min-h-10 items-center justify-center border-b-2 px-3 text-sm font-semibold transition"
				:class="activeUsersTab === 'users' ? 'border-blue-700 text-blue-700' : 'border-transparent text-slate-500 hover:text-slate-900'"
				@click="activeUsersTab = 'users'">
				Encargados
			</a>
			<a href="#admins"
				class="inline-flex min-h-10 items-center justify-center border-b-2 px-3 text-sm font-semibold transition"
				:class="activeUsersTab === 'admins' ? 'border-blue-700 text-blue-700' : 'border-transparent text-slate-500 hover:text-slate-900'"
				@click="activeUsersTab = 'admins'">
				Admins
			</a>
		</nav>
	</div>

	<div x-show="activeUsersTab === 'users'">
		<%- include("./users-list-panel", { users: regularUsers, emptyMessage: "No hay encargados creados." }) %>
	</div>

	<div x-show="activeUsersTab === 'admins'">
		<%- include("./users-list-panel", { users: adminUsers, emptyMessage: "No hay admins creados." }) %>
	</div>
</section>
