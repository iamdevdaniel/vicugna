<section
	id="assignments-permit-list-slot"
	class="mt-4 xl:flex xl:min-h-0 xl:flex-1 xl:flex-col">
	<div>
		<h3 class="text-xs font-semibold uppercase tracking-wide text-slate-700">Buscar permisos</h3>
		<div class="mt-1.5 join w-full">
			<input
				class="input input-bordered join-item w-full"
				type="text"
				x-model="permitSearch"
				placeholder="Buscar permiso" />
			<button type="button" class="btn btn-outline join-item" tabindex="-1" aria-hidden="true">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8" />
					<path d="m21 21-4.3-4.3" />
				</svg>
			</button>
		</div>
	</div>

	<div class="mt-3 xl:flex xl:min-h-0 xl:flex-1 xl:flex-col">
		<div class="mt-1.5 overflow-y-auto pr-1 xl:min-h-0 xl:flex-1">
			<template x-if="filteredPermits.length === 0">
				<p class="rounded-box border border-dashed border-base-300 px-4 py-3 text-sm text-slate-500">
					No hay permisos para mostrar.
				</p>
			</template>
			<div class="space-y-2">
				<template x-for="permit in filteredPermits" :key="permit.id">
					<button
						type="button"
						class="flex w-full items-center gap-3 rounded-box border px-4 py-3 text-left transition"
						:class="selectedPermitId === permit.id
							? 'border-primary bg-primary/5'
							: 'border-base-300 bg-base-100 hover:bg-base-200'"
						@click="selectPermit(permit)">
						<span
							class="h-10 w-1 rounded-full"
							:class="selectedPermitId === permit.id ? 'bg-primary' : 'bg-transparent'"></span>
						<div class="flex-1">
							<p class="font-medium text-slate-900" x-text="permit.permitNumber"></p>
							<p class="mt-0.5 text-xs text-slate-500" x-text="getPermitSummary(permit.id)"></p>
						</div>
						<svg
							x-show="selectedPermitId === permit.id"
							xmlns="http://www.w3.org/2000/svg"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="text-primary">
							<path d="M20 6 9 17l-5-5" />
						</svg>
					</button>
				</template>
			</div>
		</div>
	</div>
</section>
