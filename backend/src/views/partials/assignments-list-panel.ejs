<article id="assignments-list-panel" class="card relative bg-base-100 shadow xl:min-h-0">
	<div class="card-body p-4 xl:h-full xl:overflow-hidden">
		<h2 class="text-base font-semibold text-slate-900">Asignaciones</h2>

		<div class="mt-3 xl:h-full xl:overflow-y-auto">
			<template x-if="assignmentCards.length === 0">
				<p class="text-xs text-slate-500">Todavia no hay asignaciones guardadas.</p>
			</template>

			<div class="space-y-2.5" x-show="assignmentCards.length > 0" x-cloak>
				<template x-for="card in assignmentCards" :key="card.permitId">
					<article
						:data-assignment-card-id="card.permitId"
						class="rounded-box cursor-pointer border px-4 py-3 transition"
						:class="selectedPermit && selectedPermit.id === card.permitId
							? 'border-primary bg-primary/5'
							: card.users.some((user) => user.active)
								? 'border-base-300 hover:bg-base-200'
								: 'border-warning/60 bg-warning/10 hover:bg-warning/15'"
						@click="selectPermit({ id: card.permitId, permitNumber: card.permitNumber })">
						<div class="flex items-start justify-between gap-3">
							<div>
								<h3 class="font-semibold text-slate-900" x-text="card.permitNumber"></h3>
								<p class="mt-1 text-xs text-slate-500">
									<span x-text="card.seasonName"></span>
									<span> • </span>
									<span x-text="card.communityName"></span>
								</p>
							</div>
							<div class="flex items-start gap-2">
								<div
									x-show="!card.users.some((user) => user.active)"
									class="inline-flex items-center gap-1.5 rounded-full bg-warning/15 px-2 py-1 text-xs font-medium text-warning"
									title="Sin activo">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528" />
										<path d="m2 2 20 20" />
										<path d="M4 22V4" />
										<path d="M7.656 2H8c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10.347" />
									</svg>
									<span>Sin activo</span>
								</div>
								<span
									class="h-10 w-1 rounded-full"
									:class="selectedPermit && selectedPermit.id === card.permitId
										? 'bg-primary'
										: !card.users.some((user) => user.active)
											? 'bg-warning/70'
											: 'bg-transparent'"></span>
							</div>
						</div>
						<div class="mt-3 space-y-2">
							<template x-for="user in card.users" :key="user.assignmentId">
								<div class="flex items-center justify-between gap-3 rounded-box bg-base-200 px-3">
									<span class="text-sm text-slate-700" x-text="user.userFullName"></span>
									<div class="flex items-center gap-1.5">
										<button
											type="button"
											class="rounded-full p-2 transition hover:bg-base-300 cursor-pointer"
											@click.stop
											hx-post="/admin/assignments/activate"
											x-bind:hx-vals="JSON.stringify({ seasonId: selectedSeasonId, permitId: card.permitId, assignmentId: user.assignmentId })"
											hx-confirm="Marcar este encargado como principal?"
											hx-swap="none"
											:class="user.active ? 'text-success' : 'text-slate-400 hover:text-slate-600'"
											:title="user.active ? 'Encargado activo' : 'Marcar como activo'"
											aria-label="Cambiar encargado principal">
											<template x-if="user.active">
												<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
													<path d="M4 22V4a1 1 0 0 1 .4-.8A6 6 0 0 1 8 2c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10a1 1 0 0 1-.4.8A6 6 0 0 1 16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528" />
												</svg>
											</template>
											<template x-if="!user.active">
												<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
													<path d="M4 22V4a1 1 0 0 1 .4-.8A6 6 0 0 1 8 2c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10a1 1 0 0 1-.4.8A6 6 0 0 1 16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528" />
												</svg>
											</template>
										</button>
										<button
											type="button"
											class="pointer-cursor rounded-full p-2 text-slate-400 transition hover:bg-base-300 hover:text-red-600 cursor-pointer"
											@click.stop
											hx-post="/admin/assignments/delete"
											x-bind:hx-vals="JSON.stringify({ seasonId: selectedSeasonId, permitId: card.permitId, assignmentId: user.assignmentId })"
											hx-confirm="Eliminar esta asignacion?"
											hx-swap="none"
											title="Eliminar asignacion"
											aria-label="Eliminar asignacion">
											<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
												<path d="M10 11v6" />
												<path d="M14 11v6" />
												<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
												<path d="M3 6h18" />
												<path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
											</svg>
										</button>
									</div>
								</div>
							</template>
						</div>
					</article>
				</template>
			</div>
		</div>
	</div>
</article>
