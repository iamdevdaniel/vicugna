<!doctype html>
<html lang="es" data-theme="light">
<%- include("../partials/admin-head", { pageTitle }) %>

	<body class="min-h-screen bg-base-200 text-base-content">
		<main class="mx-auto max-w-6xl px-5 py-8"
			x-data="{ isCreateModalOpen: false, activeUsersTab: window.location.hash === '#admins' ? 'admins' : 'users' }"
			@hashchange.window="activeUsersTab = window.location.hash === '#admins' ? 'admins' : 'users'"
			@user-created.window="isCreateModalOpen = false; $refs.createUserForm.reset(); $refs.createUserForm.elements.password.value = ''">
			<header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-3xl font-semibold text-slate-900">Usuarios</h1>
					<p class="mt-2 text-sm text-slate-500">
						<%= adminUser.fullName %>
					</p>
				</div>

				<div class="flex items-center gap-3">
					<button type="button"
						class="btn btn-primary"
						@click="$refs.createUserForm.reset(); $refs.createUserForm.elements.password.value = ''; document.getElementById('create-user-modal-message').innerHTML = ''; isCreateModalOpen = true">
						Nuevo usuario
					</button>
					<a href="/admin/mission-control"
						class="btn btn-outline btn-primary">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-house-icon lucide-house"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
					</a>
				</div>
			</header>

			<div class="modal modal-open bg-neutral/50"
				x-show="isCreateModalOpen" x-cloak>
				<button type="button" class="modal-backdrop" aria-label="Cerrar modal"
					@click="isCreateModalOpen = false"></button>

				<section
					class="modal-box">
					<div class="flex items-start justify-between gap-4">
						<div>
							<h2 class="text-lg font-semibold text-slate-900">Nuevo usuario</h2>
						</div>
						<button type="button"
							class="btn btn-ghost btn-sm"
							@click="isCreateModalOpen = false">
							Cerrar
						</button>
					</div>

					<form x-ref="createUserForm" class="mt-5 flex flex-col gap-4" hx-post="/admin/users"
						hx-target="#create-user-modal-message" hx-swap="innerHTML">
						<div id="create-user-modal-message"></div>

						<label class="form-control">
							<span class="label-text mb-2 font-semibold">Nombre completo</span>
							<input
								class="input input-bordered w-full"
								type="text" name="fullName" autocomplete="name" />
						</label>

						<label class="form-control">
							<span class="label-text mb-2 font-semibold">Telefono</span>
							<input
								class="input input-bordered w-full"
								type="tel" name="phoneNumber" autocomplete="tel" />
						</label>

						<label class="form-control">
							<span class="label-text mb-2 flex items-center justify-between gap-3 font-semibold">
								Correo
								<span class="text-xs font-medium text-base-content/50">Opcional</span>
							</span>
							<input
								class="input input-bordered w-full"
								type="email" name="email" autocomplete="email" />
						</label>

						<%- include("../partials/users-password-field", { suggestedPassword: "" }) %>

							<div class="flex justify-end gap-3 pt-2">
								<button type="button"
									class="btn btn-ghost"
									@click="isCreateModalOpen = false">
									Cancelar
								</button>
								<button type="submit"
									class="btn btn-primary">
									<span class="htmx-request:hidden">Crear usuario</span>
									<span class="htmx-indicator">Guardando...</span>
								</button>
							</div>
					</form>
				</section>
			</div>
			<%- include("../partials/users-list", { users }) %>
				<div id="toast-container" class="pointer-events-none fixed inset-x-0 bottom-5 z-50 flex justify-center px-5"></div>
		</main>
	</body>

</html>
