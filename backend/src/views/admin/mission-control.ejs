<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0"
		/>
		<title><%= pageTitle%></title>
		<link rel="icon" href="/favicon.png" />
		<link rel="stylesheet" href="/admin.css" />
		<script src="https://cdn.tailwindcss.com"></script>
		<script
			defer
			src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
		></script>
	</head>
	<body class="min-h-screen bg-slate-100 text-slate-800">
		<main
			class="mx-auto max-w-6xl px-5 py-8"
			x-data="{ filter: 'all' }"
		>
			<header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-3xl font-semibold text-slate-900">Mission Control</h1>
				</div>

				<div class="flex items-center gap-3">
					<a
						href="/admin/login"
						class="inline-flex min-h-10 items-center justify-center rounded-lg border border-blue-700 bg-white px-4 text-sm font-semibold text-blue-700 transition hover:bg-blue-50"
					>
						Logout
					</a>
				</div>
			</header>

			<section class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
				<article class="rounded-lg border border-slate-200 bg-white p-5 shadow-lg shadow-slate-900/5">
					<span class="text-sm text-slate-500">Assigned</span>
					<strong class="mt-2 block text-3xl font-semibold text-slate-900"><%= summary.assignedPermits %></strong>
				</article>
				<article class="rounded-lg border border-slate-200 bg-white p-5 shadow-lg shadow-slate-900/5">
					<span class="text-sm text-slate-500">Synced</span>
					<strong class="mt-2 block text-3xl font-semibold text-slate-900"><%= summary.syncedPermits %></strong>
				</article>
				<article class="rounded-lg border border-slate-200 bg-white p-5 shadow-lg shadow-slate-900/5">
					<span class="text-sm text-slate-500">Completed</span>
					<strong class="mt-2 block text-3xl font-semibold text-slate-900"><%= summary.completedPermits %></strong>
				</article>
			</section>

			<section class="mt-6 rounded-lg border border-slate-200 bg-white shadow-lg shadow-slate-900/5">
				<div class="flex flex-col gap-4 border-b border-slate-200 px-5 py-5 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<h2 class="text-lg font-semibold text-slate-900">Recent activity</h2>
						<p class="mt-1 text-sm text-slate-500">
							Placeholder panel for permit sync and completion status.
						</p>
					</div>

					<div class="inline-flex rounded-lg border border-slate-200 bg-slate-50 p-1">
						<button
							type="button"
							class="rounded-md px-3 py-2 text-sm font-semibold text-slate-600 transition"
							:class="filter === 'all' ? 'bg-blue-700 text-white' : 'hover:bg-slate-100'"
							@click="filter = 'all'"
						>
							All
						</button>
						<button
							type="button"
							class="rounded-md px-3 py-2 text-sm font-semibold text-slate-600 transition"
							:class="filter === 'synced' ? 'bg-blue-700 text-white' : 'hover:bg-slate-100'"
							@click="filter = 'synced'"
						>
							Synced
						</button>
						<button
							type="button"
							class="rounded-md px-3 py-2 text-sm font-semibold text-slate-600 transition"
							:class="filter === 'completed' ? 'bg-blue-700 text-white' : 'hover:bg-slate-100'"
							@click="filter = 'completed'"
						>
							Completed
						</button>
					</div>
				</div>

				<div class="px-5 py-8 text-sm text-slate-600">
					No admin data wired yet.
				</div>
			</section>
		</main>
	</body>
</html>
