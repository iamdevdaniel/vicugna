<!doctype html>
<html lang="en" data-theme="light">
<%- include("../partials/admin-head", { pageTitle }) %>

	<body class="min-h-screen bg-base-200 text-base-content">
		<main class="mx-auto max-w-6xl px-5 py-8">
			<header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-3xl font-semibold text-slate-900">Inicio</h1>
					<p class="mt-2 text-sm text-slate-500">
						<%= adminUser.fullName %>
					</p>
				</div>

				<div class="flex items-center gap-3">
					<form method="post" action="/admin/logout">
						<button type="submit"
							class="btn btn-outline btn-primary">
							Cerrar sesion
						</button>
					</form>
				</div>
			</header>

			<section class="card mt-6 bg-base-100 shadow">
				<div class="card-body">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
						<div>
							<h2 class="card-title">Temporada actual</h2>
							<p class="text-sm text-slate-500">
								Todavia no hay una temporada cargada desde la interfaz.
							</p>
						</div>
						<span class="badge badge-warning badge-soft">Pendiente</span>
					</div>
				</div>
			</section>

			<section class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-4">
				<article class="card bg-base-100 shadow">
					<div class="card-body">
						<span class="text-sm text-slate-500">Encargados</span>
						<strong class="mt-2 block text-3xl font-semibold text-slate-900">0</strong>
					</div>
				</article>
				<article class="card bg-base-100 shadow">
					<div class="card-body">
						<span class="text-sm text-slate-500">Asignaciones</span>
						<strong class="mt-2 block text-3xl font-semibold text-slate-900">0</strong>
					</div>
				</article>
				<article class="card bg-base-100 shadow">
					<div class="card-body">
						<span class="text-sm text-slate-500">Permisos</span>
						<strong class="mt-2 block text-3xl font-semibold text-slate-900">0</strong>
					</div>
				</article>
				<article class="card bg-base-100 shadow">
					<div class="card-body">
						<span class="text-sm text-slate-500">Completados</span>
						<strong class="mt-2 block text-3xl font-semibold text-slate-900">0</strong>
					</div>
				</article>
			</section>

			<section class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
				<article class="card bg-base-100 shadow">
					<div class="card-body">
						<h2 class="card-title">Encargados</h2>
						<p class="text-sm text-slate-500">
							Crear usuarios y revisar quienes tienen acceso a la app.
						</p>
						<div class="card-actions justify-end">
							<a href="/admin/users" class="btn btn-primary">Abrir</a>
						</div>
					</div>
				</article>

				<article class="card bg-base-100 shadow">
					<div class="card-body">
						<h2 class="card-title">Asignaciones</h2>
						<p class="text-sm text-slate-500">
							Asignar comunidad, encargado y permisos para la temporada.
						</p>
						<div class="card-actions justify-end">
							<button type="button" class="btn btn-disabled">Pendiente</button>
						</div>
					</div>
				</article>

				<article class="card bg-base-100 shadow">
					<div class="card-body">
						<h2 class="card-title">Seguimiento</h2>
						<p class="text-sm text-slate-500">
							Ver sincronizacion, completitud y generar el Excel final.
						</p>
						<div class="card-actions justify-end">
							<button type="button" class="btn btn-disabled">Pendiente</button>
						</div>
					</div>
				</article>
			</section>
		</main>
	</body>

</html>
