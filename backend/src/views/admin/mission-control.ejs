<!doctype html>
<html lang="en" data-theme="light">
<%- include("../partials/admin-head", { pageTitle }) %>

	<body class="min-h-screen bg-base-200 text-base-content">
		<main class="mx-auto max-w-6xl px-5 py-8" x-data="{ filter: 'all' }">
			<header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-3xl font-semibold text-slate-900">Panel de control</h1>
					<p class="mt-2 text-sm text-slate-500">
						<%= adminUser.fullName %>
					</p>
				</div>

				<div class="flex items-center gap-3">
					<form method="post" action="/admin/logout">
						<button type="submit"
							class="btn btn-outline btn-primary">
							Cerrar sesion
						</button>
					</form>
				</div>
			</header>

			<section class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
				<article class="card bg-base-100 shadow">
					<div class="card-body">
					<span class="text-sm text-slate-500">Asignados</span>
					<strong class="mt-2 block text-3xl font-semibold text-slate-900">
						<%= summary.assignedPermits %>
					</strong>
					</div>
				</article>
				<article class="card bg-base-100 shadow">
					<div class="card-body">
					<span class="text-sm text-slate-500">Sincronizados</span>
					<strong class="mt-2 block text-3xl font-semibold text-slate-900">
						<%= summary.syncedPermits %>
					</strong>
					</div>
				</article>
				<article class="card bg-base-100 shadow">
					<div class="card-body">
					<span class="text-sm text-slate-500">Completados</span>
					<strong class="mt-2 block text-3xl font-semibold text-slate-900">
						<%= summary.completedPermits %>
					</strong>
					</div>
				</article>
			</section>

			<section class="card mt-6 bg-base-100 shadow">
				<div
					class="flex flex-col gap-4 border-b border-base-300 px-5 py-5 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<h2 class="text-lg font-semibold text-slate-900">Actividad reciente</h2>
						<p class="mt-1 text-sm text-slate-500">
							Panel provisional para sincronizacion y estado de completitud.
						</p>
					</div>

					<div class="join">
						<button type="button"
							class="btn join-item btn-sm"
							:class="filter === 'all' ? 'btn-primary' : 'btn-outline'"
							@click="filter = 'all'">
							Todos
						</button>
						<button type="button"
							class="btn join-item btn-sm"
							:class="filter === 'synced' ? 'btn-primary' : 'btn-outline'"
							@click="filter = 'synced'">
							Sincronizados
						</button>
						<button type="button"
							class="btn join-item btn-sm"
							:class="filter === 'completed' ? 'btn-primary' : 'btn-outline'"
							@click="filter = 'completed'">
							Completados
						</button>
					</div>
				</div>

				<div class="px-5 py-8 text-sm text-slate-600">
					Aun no hay datos de administracion cargados.
				</div>
			</section>
		</main>
	</body>

</html>
