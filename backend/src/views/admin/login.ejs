<!doctype html>
<html lang="en" data-theme="light">
<%- include("../partials/admin-head", { pageTitle }) %>

	<body class="min-h-screen bg-base-200 text-base-content">
		<main class="mx-auto flex min-h-screen max-w-6xl items-center justify-center px-5 py-12">
			<section
				class="card w-full max-w-md bg-base-100 shadow"
				x-data="{ showHelp: false }">
				<div class="card-body">
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-2xl font-semibold text-slate-900">Inicio de sesion</h1>
					<p class="mt-2 text-sm text-slate-500">
						Acceso de administracion para asignacion y seguimiento de permisos.
					</p>

				<form method="post" action="/admin/login" class="flex flex-col gap-4" x-data="{showPassword: false}">
					<% if (errorMessage) { %>
						<div class="alert alert-error alert-soft">
							<%= errorMessage %>
						</div>
						<% } %>

							<label class="form-control">
								<span class="label-text mb-2 font-semibold">Correo</span>
								<input
									class="input input-bordered w-full"
									type="email" placeholder="correo@ejemplo.com" name="email" value="<%= email %>"
									autocomplete="username" />
							</label>

							<label class="form-control">
								<span class="label-text mb-2 font-semibold">Contrasena</span>
								<div class="relative">
									<input
										class="input input-bordered w-full pr-12"
										:type="showPassword ? 'text': 'password'" placeholder="********" name="password"
										autocomplete="current-password" />
									<button type="button" @click="showPassword = !showPassword"
										class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-700"
										:aria-label="showPassword ? 'Ocultar contraseña' : 'Mostrar contraseña'">
										<span x-show="!showPassword">
											<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
												viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
												stroke-linecap="round" stroke-linejoin="round"
												class="lucide lucide-eye-icon lucide-eye">
												<path
													d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" />
												<circle cx="12" cy="12" r="3" />
											</svg>
										</span>
										<span x-show="showPassword">
											<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
												viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
												stroke-linecap="round" stroke-linejoin="round"
												class="lucide lucide-eye-off-icon lucide-eye-off">
												<path
													d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49" />
												<path d="M14.084 14.158a3 3 0 0 1-4.242-4.242" />
												<path
													d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143" />
												<path d="m2 2 20 20" />
											</svg>
										</span>
									</button>
								</div>
							</label>

							<div class="flex flex-col gap-3 pt-2 sm:flex-row">
								<button type="submit"
									class="btn btn-primary">
									Entrar
								</button>
								<button type="button"
									class="btn btn-outline btn-primary"
									@click="showHelp = !showHelp">
									Ayuda
								</button>
							</div>
				</form>

				<p class="mt-4 text-sm text-slate-500" x-show="showHelp" x-cloak>
					La ayuda del acceso todavia es provisional.
				</p>
				</div>
			</section>
		</main>
	</body>

</html>
