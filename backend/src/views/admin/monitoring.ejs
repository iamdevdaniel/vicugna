<!doctype html>
<html lang="es" data-theme="light">
<%- include("../partials/admin-head", { pageTitle }) %>

	<body class="min-h-screen bg-base-200 text-base-content">
		<main class="mx-auto max-w-6xl px-5 py-8">
			<header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-3xl font-semibold text-slate-900">Seguimiento</h1>
					<p class="mt-2 text-sm text-slate-500">
						<%= adminUser.fullName %>
					</p>
				</div>

				<div class="flex items-center gap-3">
					<a href="/admin/mission-control" class="btn btn-outline btn-primary">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
							fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							stroke-linejoin="round" class="h-5 w-5">
							<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
							<path
								d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
						</svg>
					</a>
				</div>
			</header>

			<section class="card mt-6 bg-base-100 shadow">
				<div class="card-body flex min-h-80 items-center justify-center">
					<p class="text-sm text-slate-500">Sin datos todavia.</p>
				</div>
			</section>
		</main>
	</body>

</html>
