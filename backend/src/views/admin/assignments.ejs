<!doctype html>
<html lang="es" data-theme="light">
<%- include("../partials/admin-head", { pageTitle }) %>

	<body class="min-h-screen bg-base-200 text-base-content">
		<main class="mx-auto flex w-full max-w-7xl flex-col px-4 py-4 lg:h-screen lg:overflow-hidden">
			<header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-2xl font-semibold text-slate-900">Asignaciones</h1>
					<p class="mt-1.5 text-xs text-slate-500">
						<%= adminUser.fullName %>
					</p>
				</div>

				<div class="flex items-center gap-3">
					<a href="/admin/mission-control" class="btn btn-outline btn-primary">
						Inicio
					</a>
				</div>
			</header>

			<section class="mt-3 card bg-base-100 shadow">
				<div class="card-body p-4">
					<form method="get" action="/admin/assignments" class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
						<label class="form-control w-full md:max-w-xs">
							<span class="label-text mb-2 font-semibold">Temporada</span>
							<select class="select select-bordered w-full" name="seasonId" onchange="this.form.submit()">
								<% seasons.forEach((season) => { %>
									<option value="<%= season.id %>" <%= selectedSeasonId === season.id ? "selected" : "" %>>
										<%= season.name %>
									</option>
								<% }) %>
							</select>
						</label>

						<div class="flex flex-wrap items-center gap-3 md:justify-end">
							<div class="inline-flex items-center gap-2 rounded-full bg-base-200 px-3 py-2 text-sm font-medium text-slate-700">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="18" height="18"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="lucide lucide-house-icon lucide-house">
									<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/>
									<path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
								</svg>
								<span><%= communitiesWithPermitsCount %> comunidades</span>
							</div>

							<div class="inline-flex items-center gap-2 rounded-full bg-base-200 px-3 py-2 text-sm font-medium text-slate-700">
								<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M14 2v5a1 1 0 0 0 1 1h5" />
									<path d="M4 12v6" />
									<path d="M4 14h2" />
									<path d="M9.65 22H18a2 2 0 0 0 2-2V8a2.4 2.4 0 0 0-.706-1.706l-3.588-3.588A2.4 2.4 0 0 0 14 2H6a2 2 0 0 0-2 2v4" />
									<circle cx="4" cy="20" r="2" />
								</svg>
								<span><%= permitsCount %> permisos</span>
							</div>
						</div>
					</form>
				</div>
			</section>

			<section
				x-data='assignmentPageState({
					permits: <%- JSON.stringify(permits) %>,
					communities: <%- JSON.stringify(communities) %>,
					users: <%- JSON.stringify(users) %>,
					assignmentCards: <%- JSON.stringify(assignmentCards) %>,
					selectedCommunityId: <%- JSON.stringify(selectedCommunityId) %>,
					selectedPermit: <%- JSON.stringify(selectedPermit) %>
				})'
				class="mt-3 grid grid-cols-1 items-start gap-4 lg:min-h-0 lg:flex-1 lg:grid-cols-3 lg:items-stretch">
				<%- include("../partials/assignments-panel-permits", { permits }) %>
				<%- include("../partials/assignments-panel-users") %>
				<%- include("../partials/assignments-panel-list", { assignments }) %>
			</section>
		</main>
		<% if (formMessage) { %>
			<div
				x-data="{ visible: true }"
				x-init="
					const url = new URL(window.location.href)
					url.searchParams.delete('success')
					url.searchParams.delete('error')
					window.history.replaceState({}, '', `${url.pathname}${url.search}`)
					setTimeout(() => { visible = false }, 3500)
				"
				x-show="visible"
				x-transition:enter="transform transition ease-out duration-300"
				x-transition:enter-start="translate-x-8 opacity-0"
				x-transition:enter-end="translate-x-0 opacity-100"
				x-transition:leave="transform transition ease-in duration-200"
				x-transition:leave-start="translate-x-0 opacity-100"
				x-transition:leave-end="translate-x-8 opacity-0"
				class="pointer-events-none fixed bottom-5 right-5 z-50 w-full max-w-md px-4 sm:px-0">
				<div class="alert w-full shadow-lg <%= formMessageType === 'error' ? 'alert-error' : 'alert-success' %>">
					<span><%= formMessage %></span>
				</div>
			</div>
		<% } %>
		<script src="/views/admin/assignments.js"></script>
	</body>
</html>
