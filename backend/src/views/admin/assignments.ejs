<!doctype html>
<html lang="es" data-theme="light">
<%- include("../partials/admin-head", { pageTitle }) %>

	<body class="min-h-screen bg-base-200 text-base-content">
		<main class="mx-auto flex max-w-7xl flex-col px-4 py-4 xl:h-screen xl:overflow-hidden">
			<header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-500">
						Vicugna Admin
					</p>
					<h1 class="text-2xl font-semibold text-slate-900">Asignaciones</h1>
					<p class="mt-1.5 text-xs text-slate-500">
						<%= adminUser.fullName %>
					</p>
				</div>

				<div class="flex items-center gap-3">
					<a href="/admin/mission-control" class="btn btn-outline btn-primary">
						Inicio
					</a>
				</div>
			</header>

			<section class="mt-3 card bg-base-100 shadow">
				<div class="card-body p-4">
					<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
						<div>
							<h2 class="card-title">Temporada activa</h2>
						</div>
						<label class="form-control w-full md:max-w-xs">
							<span class="label-text mb-2 font-semibold">Temporada</span>
							<select
								class="select select-bordered w-full"
								name="seasonId"
								hx-get="/admin/assignments/season-state"
								hx-trigger="change"
								hx-target="#season-state-slot"
								hx-swap="innerHTML"
								hx-include="[name='seasonId']"
								hx-indicator="#assignment-user-picker-loading, #assignments-list-loading">
								<% seasons.forEach((season) => { %>
									<option value="<%= season.id %>" <%= selectedSeasonId === season.id ? "selected" : "" %>>
										<%= season.name %>
									</option>
								<% }) %>
							</select>
						</label>
					</div>
				</div>
			</section>

			<section id="season-state-slot" class="mt-3 xl:min-h-0 xl:flex-1 xl:overflow-hidden">
				<%- include("../partials/assignments-season-panels", { formMessage, selectedSeasonId, selectedPermit, seasons, permits, communities, users, assignments }) %>
			</section>

			<div id="toast-container" class="pointer-events-none fixed inset-x-0 bottom-5 z-50 flex justify-center px-5"></div>
		</main>
		<script src="/views/admin/assignments.js"></script>
	</body>

</html>
