  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "db:start": "wsl -e bash -lc \"cd /mnt/d/Code/vicugna/backend && docker compose up -d\"",
    "db:stop": "wsl -e bash -lc \"cd /mnt/d/Code/vicugna/backend && docker compose down\"",
    "db:status": "wsl -e bash -lc \"docker ps --filter name=vicugna-postgres\"",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "echo \"No backend tests yet\""
  },
