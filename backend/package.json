{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "tscheck": "tsc --noEmit",
    "db:start": "wsl -e bash -lc \"cd /mnt/d/Code/vicugna/backend && docker compose up -d\"",
    "db:stop": "wsl -e bash -lc \"cd /mnt/d/Code/vicugna/backend && docker compose down\"",
    "db:status": "wsl -e bash -lc \"docker ps --filter name=vicugna-postgres\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:regionals": "npm run build && node dist/db/seed-regionals.js",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check src drizzle.config.ts",
    "lint-fix": "biome check --write src drizzle.config.ts",
    "test": "echo \"No backend tests yet\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "npm": "^11.17.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.14",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome check --write --no-errors-on-unmatched",
      "biome check --error-on-warnings --no-errors-on-unmatched"
    ],
    "drizzle.config.ts": [
      "biome check --write --no-errors-on-unmatched",
      "biome check --error-on-warnings --no-errors-on-unmatched"
    ]
  }
}
