{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run css:watch\"",
    "dev:server": "tsx watch --clear-screen=false src/server.ts",
    "build": "npm run css:build && npm run build:ts",
    "build:ts": "tsc && tsc-alias",
    "css:build": "tailwindcss -i src/public/admin.input.css -o src/public/admin.css --minify",
    "css:watch": "tailwindcss -i src/public/admin.input.css -o src/public/admin.css --watch",
    "tscheck": "tsc --noEmit",
    "db": "node scripts/db.cjs",
    "lint": "biome check src drizzle.config.ts",
    "lint-fix": "biome check --write src drizzle.config.ts",
    "test": "echo \"No backend tests yet\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "npm": "^11.17.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/cli": "^4.3.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "daisyui": "^5.5.23",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.6",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome check --write --no-errors-on-unmatched",
      "biome check --error-on-warnings --no-errors-on-unmatched"
    ],
    "drizzle.config.ts": [
      "biome check --write --no-errors-on-unmatched",
      "biome check --error-on-warnings --no-errors-on-unmatched"
    ]
  }
}
