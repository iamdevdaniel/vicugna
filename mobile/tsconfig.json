{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "experimentalDecorators": true,
    "strict": true,
    "paths": {
      "@app/*": ["./app/*"],
      "@definitions/*": ["./definitions/*"],
      "@assets/*": ["./assets/*"],
      "@utils/*": ["./utils/*"],
      "@database": ["./database/index"],
      "@components": ["./components/index"],
      "@hooks": ["./hooks/index"],
      "@vicugna/shared": ["../packages/shared/index.d.ts"],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
